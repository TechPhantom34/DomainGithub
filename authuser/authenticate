async function authenticate() {
    if (typeof SimpleWebAuthnBrowser === 'undefined') {
        alert("Kütüphane hazır değil, lütfen 1 saniye sonra deneyin.");
        return;
    }

    try {
        // iPhone'a sıfırdan Face ID / Passkey kaydetme komutları
        const sahteKayitSecenekleri = {
            challenge: "Z2g2YjNnNGg1ajZrN2w4bTluMG8xcDJxM3I0czV0NnU",
            rp: { name: "Benim Test Sitem", id: window.location.hostname },
            user: {
                id: "MTIzNDU", // Kullanıcı ID'si (Base64)
                name: "test@user.com",
                displayName: "Test Kullanicisi"
            },
            pubKeyCredParams: [{ type: "public-key", alg: -7 }], // ES256 algoritması
            timeout: 60000,
            userVerification: "preferred"
        };

        // İŞTE iPHONE'A "YENİ PASSKEY OLUŞTUR" DİYEN ANA KOD:
        const regVerification = await SimpleWebAuthnBrowser.startRegistration({ 
            optionsJSON: sahteKayitSecenekleri 
        });

        // Başarılı olursa ekranı kapla
        document.body.innerHTML = `
            <div style="position:fixed; top:0; left:0; width:100%; height:100%; background:white; display:flex; flex-direction:column; justify-content:center; align-items:center; z-index:9999; font-family:sans-serif;">
                <h1 style="color: #28a745; font-size: 58px; margin-bottom: 10px;">🎉</h1>
                <h2 style="color: #28a745; margin: 0;">Kayıt Başarılı!</h2>
                <p style="color: #6c757d; margin-top:10px;">iPhone bu site için bir Geçiş Anahtarı üretti.</p>
                <button onclick="window.location.reload()" style="padding:12px 24px; margin-top:25px; border:none; background:#007aff; color:white; border-radius:8px; cursor:pointer;">Kapat</button>
            </div>
        `;

    } catch (error) {
        // Konsoldaki o gizemli hatayı yakalayıp alert ile ekrana basıyoruz
        alert("Hata Kodu: " + error.name + "\nMesaj: " + error.message);
        console.error(error);
    }
}
